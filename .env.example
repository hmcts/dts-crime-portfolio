# Copy to .env.local for local development. Never commit a populated .env file.

# Application environment. One of: production | preview | local
APP_ENVIRONMENT=local

# Sanity. Project ID is non-secret and is also hardcoded as a default in
# sanity.config.ts; setting it here lets local dev override the default.
NEXT_PUBLIC_SANITY_PROJECT_ID=vi5mhbtl
NEXT_PUBLIC_SANITY_DATASET=preview

# Server-only API token. Generate at:
#   https://manage.sanity.io/projects/vi5mhbtl/api/tokens
# Role: Editor. Scope: the dataset above only.
# SANITY_API_TOKEN=

# Admin allowlist — comma- or whitespace-separated emails.
# Anyone here is granted Admin (can edit any project, manage allowlists,
# create snapshots, edit action plan progress).
# ADMIN_ALLOWLIST=

# Preview-auth cookie secret — required when APP_ENVIRONMENT=preview|local
# Generate with: openssl rand -hex 32
# PREVIEW_AUTH_COOKIE_SECRET=

# Analytics (PostHog) — all optional locally. Without these, the consent
# banner still renders and unit/e2e tests still pass; events just won't
# reach a real PostHog instance. Set them to wire a local PostHog target.
# Spec: openspec/specs/analytics/spec.md.

# PostHog Project API key (the `phc_…` value). Server-side only when
# ANALYTICS_INGEST_MODE=proxy.
# POSTHOG_PROJECT_KEY=

# Region-dependent ingest URL. EU Cloud (default):
# https://eu.i.posthog.com. US Cloud: https://us.i.posthog.com.
# POSTHOG_INGEST_URL=

# `direct` (default) sends events from the browser straight to PostHog
# with the project key visible client-side. `proxy` routes through the
# same-origin /api/analytics/ingest route so the project key stays on
# the server. Recommended: proxy.
# ANALYTICS_INGEST_MODE=proxy

# Salt mixed into the SHA-256 of the user's email to produce a stable
# distinct_id. Generate with `openssl rand -hex 32`. Without this set
# events are sent with `distinct_id: anonymous`.
# ANALYTICS_USER_ID_PEPPER=

# `true` strips x-forwarded-for / x-real-ip before the proxy forwards
# to PostHog. Privacy-by-default.
# ANALYTICS_DROP_IP=true
