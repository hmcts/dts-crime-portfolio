# Copy to .env.local for local development. Never commit a populated .env file.

# Application environment. One of: production | preview | local
APP_ENVIRONMENT=local

# Sanity. Project ID is non-secret and is also hardcoded as a default in
# sanity.config.ts; setting it here lets local dev override the default.
NEXT_PUBLIC_SANITY_PROJECT_ID=vi5mhbtl
NEXT_PUBLIC_SANITY_DATASET=preview

# Server-only API token. Generate at:
#   https://manage.sanity.io/projects/vi5mhbtl/api/tokens
# Role: Editor. Scope: the dataset above only.
# SANITY_API_TOKEN=

# Admin allowlist — comma- or whitespace-separated emails.
# Anyone here is granted Admin (can edit any project, manage allowlists,
# create snapshots, edit action plan progress).
# ADMIN_ALLOWLIST=

# Preview-auth cookie secret — required when APP_ENVIRONMENT=preview|local
# Generate with: openssl rand -hex 32
# PREVIEW_AUTH_COOKIE_SECRET=
